{
  "name": "@lueur/api",
  "version": "0.0.0",
  "private": true,
  "description": "Lueur HTTP API. Bun runtime, Hono framework. See docs/01-STACK.md.",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openapi:export": "bun run src/scripts/export-openapi.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@lueur/db": "workspace:*",
    "@lueur/prompts": "workspace:*",
    "@lueur/shared-types": "workspace:*",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.9.0",
    "pino": "^9.5.0",
    "resend": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "catalog:",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.3.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
