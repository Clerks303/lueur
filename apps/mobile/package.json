{
  "name": "@lueur/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Lueur mobile app — Expo SDK 55, TypeScript strict, Expo Router, NativeWind.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "api:gen": "openapi-typescript ../../packages/shared-types/openapi.json -o src/api/schema.ts",
    "icons:gen": "bun scripts/generate-icons.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^14.0.4",
    "@lueur/shared-types": "workspace:*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~55.0.15",
    "expo-camera": "~17.0.0",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.0",
    "expo-linking": "~8.0.0",
    "expo-localization": "~17.0.0",
    "expo-notifications": "~0.32.0",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "i18n-js": "^4.5.1",
    "nativewind": "^4.2.0",
    "openapi-fetch": "^0.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.82.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/i18n-js": "^3.8.9",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "~14.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "openapi-typescript": "^7.4.0",
    "pngjs": "^7.0.0",
    "@types/pngjs": "^6.0.5",
    "react-test-renderer": "19.2.0",
    "typescript": "catalog:"
  }
}
