{
  "name": "lueur",
  "version": "0.0.0",
  "private": true,
  "description": "Une app qui apprend ton goût. Et s'en souvient.",
  "license": "MIT",
  "author": "Romain Sultan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Clerks303/lueur.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:infra": "docker compose -f infra/docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker-compose.dev.yml down",
    "dev:infra:reset": "docker compose -f infra/docker-compose.dev.yml down -v",
    "dev:infra:logs": "docker compose -f infra/docker-compose.dev.yml logs -f",
    "dev:infra:ps": "docker compose -f infra/docker-compose.dev.yml ps",
    "typecheck": "pnpm -r --parallel --stream typecheck",
    "test": "pnpm -r --parallel --stream test",
    "build": "pnpm -r --stream build --if-present",
    "lint": "echo \"lint setup deferred (no ESLint until needed)\" && exit 0",
    "clean": "pnpm -r --parallel exec rm -rf dist node_modules/.cache tsconfig.tsbuildinfo",
    "db:generate": "pnpm --filter @lueur/db db:generate",
    "db:migrate": "pnpm --filter @lueur/db db:migrate",
    "db:seed": "pnpm --filter @lueur/db db:seed",
    "db:studio": "pnpm --filter @lueur/db db:studio",
    "db:push": "pnpm --filter @lueur/db db:push",
    "db:reset": "pnpm dev:infra:reset && docker compose -f infra/docker-compose.dev.yml up -d --wait && pnpm db:migrate && pnpm db:seed",
    "dev:api": "pnpm --filter @lueur/api dev",
    "dev:worker": "pnpm --filter @lueur/worker dev",
    "dev:mobile": "pnpm --filter @lueur/mobile start",
    "dev:all": "pnpm dev:infra && concurrently -n api,worker -c blue,magenta \"pnpm dev:api\" \"pnpm dev:worker\"",
    "api:openapi": "pnpm --filter @lueur/api openapi:export",
    "mobile:api:gen": "pnpm api:openapi && pnpm --filter @lueur/mobile api:gen",
    "mobile:ios": "pnpm --filter @lueur/mobile ios",
    "mobile:android": "pnpm --filter @lueur/mobile android",
    "mobile:icons": "pnpm --filter @lueur/mobile icons:gen"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "concurrently": "^9.1.2",
    "typescript": "catalog:"
  }
}
