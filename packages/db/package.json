{
  "name": "@lueur/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, migrations, and taste graph derivation. Source of truth for the DB.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
