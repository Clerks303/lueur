# ---------------------------------------------------------------
# Lueur — local development environment (example).
# Copy to `.env.local` and fill with real values. NEVER commit `.env.local`.
# ---------------------------------------------------------------

# --- Postgres (local Docker) ---
# Port 54329 (not 5432) to avoid collisions with other local Postgres instances.
POSTGRES_USER=lueur
POSTGRES_PASSWORD=lueur_dev_pw
POSTGRES_DB=lueur
POSTGRES_PORT=54329
# Full URL consumed by Drizzle and the API
DATABASE_URL=postgres://lueur:lueur_dev_pw@localhost:54329/lueur

# --- Redis (local Docker) ---
# Port 63799 (not 6379) for the same collision-avoidance reason.
REDIS_PORT=63799
REDIS_URL=redis://localhost:63799

# --- API (Hono / Bun) ---
# Listen on 0.0.0.0 so a physical iPhone on the same WiFi can reach it.
# Port 3200 (not 3000) to avoid collisions with common local dev servers.
API_HOST=0.0.0.0
API_PORT=3200
NODE_ENV=development
# Permissive CORS for local dev only. Tightened per-origin in prod.
API_CORS_ORIGIN=*
# Comma-separated list of origins Better Auth will accept.
API_TRUSTED_ORIGINS=http://localhost:3200,http://localhost:8081,http://localhost:19006

# --- Auth (Better Auth) ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3200

# --- Anthropic (Claude) ---
# Needed at T07 (worker) when we wire up interior_analysis_v1.
ANTHROPIC_API_KEY=

# --- OpenAI (embeddings only) ---
# Needed when we start embedding items catalogue (post-week-1).
OPENAI_API_KEY=

# --- Object storage (dev: MinIO; prod: Scaleway) ---
# Values below match the MinIO container we'll add at T06.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lueur-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- Email (magic links via Resend) ---
# Needed once we wire Better Auth magic link flow.
RESEND_API_KEY=
RESEND_FROM=no-reply@lueur.local

# --- Mobile (Expo) ---
# Consumed by the mobile app in apps/mobile/.env; duplicated here for discoverability.
# iOS simulator: http://localhost:3200
# Physical iPhone on LAN: http://<mac-lan-ip>:3200 (get via: ipconfig getifaddr en0)
EXPO_PUBLIC_API_URL=http://localhost:3200
